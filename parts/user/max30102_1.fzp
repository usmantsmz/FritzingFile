<?xml version='1.0' encoding='UTF-8' standalone='no'?>
<module fritzingVersion="0.9.3b" moduleId="max30102_1" referenceFile="max30102_1.fzp">
  <version>1</version>
  <date>Sun Nov 17 2019</date>
  <author>Peter Van Epp (vanepp in forums)</author>
  <description>Oximeter module using the MAX30102 chip. You may wish to read (and check your module) this post on power problems with these modules: https://reedpaper.wordpress.com/2018/08/22/pulse-oximeter-max30100-max30102-how-to-fix-wrong-board/ . As usual, if you want the mounting holes in pcb, you need to drag a hole over the pad in silkscreen to actually drill the hole (by default they are not drilled)</description>
  <title>MAX30102</title>
  <tags>
    <tag>Oximeter</tag>
    <tag>contrib</tag>
    <tag>MAX30102</tag>
    <tag>Heart Rate Sensor</tag>
  </tags>
  <properties>
    <property name="family">Oximeter</property>
    <property name="variant">variant 1</property>
    <property name="layer"/>
  </properties>
  <views>
    <breadboardView>
      <layers image="breadboard/max30102_1_breadboard.svg">
        <layer layerId="breadboard"/>
      </layers>
    </breadboardView>
    <schematicView>
      <layers image="schematic/max30102_1_schematic.svg">
        <layer layerId="schematic"/>
      </layers>
    </schematicView>
    <pcbView>
      <layers image="pcb/max30102_1_pcb.svg">
        <layer layerId="copper1"/>
        <layer layerId="silkscreen"/>
        <layer layerId="copper0"/>
      </layers>
    </pcbView>
    <iconView>
      <layers image="breadboard/max30102_1_breadboard.svg">
        <layer layerId="icon"/>
      </layers>
    </iconView>
  </views>
