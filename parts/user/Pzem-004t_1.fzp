<module moduleId="Pzem-004t_1" referenceFile="Pzem-004t_1.fzp" fritzingVersion="0.9.6">
  <version>1</version>
  <author>Peter Van Epp (vanepp in forums)</author>
  <title>Pzem-004t</title>
  <label>M</label>
  <date>Mon Jun 28 2021</date>
  <tags>
    <tag>contrib</tag>
    <tag>power line Sensor</tag>
    <tag>Pzem-004t</tag>
